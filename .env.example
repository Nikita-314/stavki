BOT_TOKEN=
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/stavki
DEBUG=false
ADMIN_USER_IDS=список Telegram user_id админов, которым разрешены debug/admin команды. Формат — через запятую, например ADMIN_USER_IDS=123456789,987654321. Если оставить пустым — доступ к debug-командам будет разрешён всем (как сейчас заложено в _is_allowed).
SIGNAL_CHAT_ID=ID чата/канала, куда бот будет отправлять уведомления о новых сигналах (когда они включены через orchestration/notify-команды). Если пусто — уведомления о сигналах не отправляются.
RESULT_CHAT_ID=ID чата/канала, куда бот будет отправлять уведомления об итогах (результатах) сигналов. Если пусто — result-уведомления не отправляются.
VIRTUAL_FLAT_STAKE_RUB=1000.00
VIRTUAL_START_BALANCE_RUB=50000.00

